{% comment %}
  Product Card Enhancements — dark theme, shadows, hover effects, badges
{% endcomment %}

<style>
  /* Product card — dark surface */
  .product-card__content {
    background: #111111;
    border: 1px solid #1E1E1E;
    border-radius: 0;
    transition: border-color 0.15s ease;
  }

  .product-card:hover .product-card__content {
    border-color: #F5A623;
  }

  /* Product card image container */
  .product-card .card-gallery,
  .product-card slideshow-component {
    background: #151515;
    border-radius: 0;
    overflow: hidden;
  }

  /* Sale badge */
  .product-card .badge--sale,
  .product-card [data-badge-type="sale"] {
    background: #FF4E4E !important;
    color: #fff !important;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 0;
  }

  /* Sold out badge */
  .product-card .badge--sold-out,
  .product-card [data-badge-type="sold_out"] {
    background: #666 !important;
    color: #fff !important;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 0;
  }

  /* Product title in cards */
  .product-card .product-card__content .typography-style a,
  .product-card .product-card__content [data-testid="product-title"] {
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #CCCCCC;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Price styling in cards */
  .product-card .price {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    color: #F5A623;
  }

  .product-card .price--on-sale .price-item--regular {
    color: #3A3A3A;
    text-decoration: line-through;
  }

  .product-card .price--on-sale .price-item--sale {
    color: #F5A623;
    font-weight: 700;
  }

  /* Collection page specific */
  .main-collection .product-grid__card {
    background: #111111;
    border-radius: 0;
    overflow: hidden;
    box-shadow: none;
  }

  /* Add to cart quick-add button */
  .product-card .quick-add__button {
    background: #F5A623;
    color: #111;
    border-radius: 0;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
  }

  .product-card .quick-add__button:hover {
    background: #FFB93A;
  }

  /* Section headings */
  .product-list h2, .product-list h3,
  .collection-list h2 {
    font-family: 'Barlow Condensed', sans-serif;
    color: #E8E6E0;
  }
</style>
