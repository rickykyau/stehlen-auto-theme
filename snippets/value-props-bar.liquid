{% comment %}
  Value Props Bar — 4-column trust indicators displayed on homepage
{% endcomment %}

{% if template.name == 'index' %}
<div class="value-props-bar color-scheme-1">
  <div class="value-props-bar__inner">
    <div class="value-props-bar__item">
      <div class="value-props-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
      </div>
      <div class="value-props-bar__text">
        <span class="value-props-bar__title">Free Shipping</span>
        <span class="value-props-bar__subtitle">On all orders</span>
      </div>
    </div>
    <div class="value-props-bar__item">
      <div class="value-props-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
      </div>
      <div class="value-props-bar__text">
        <span class="value-props-bar__title">Guaranteed Fitment</span>
        <span class="value-props-bar__subtitle">Fits your vehicle or money back</span>
      </div>
    </div>
    <div class="value-props-bar__item">
      <div class="value-props-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4l2 2"></path></svg>
      </div>
      <div class="value-props-bar__text">
        <span class="value-props-bar__title">Manufacturer Warranty</span>
        <span class="value-props-bar__subtitle">On every product</span>
      </div>
    </div>
    <div class="value-props-bar__item">
      <div class="value-props-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
      </div>
      <div class="value-props-bar__text">
        <span class="value-props-bar__title">Easy Returns</span>
        <span class="value-props-bar__subtitle">30-day hassle-free returns</span>
      </div>
    </div>
  </div>
</div>

<style>
  .value-props-bar {
    background: #ffffff;
    border-bottom: 1px solid #e0e0e0;
  }

  .value-props-bar__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .value-props-bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 18px 12px;
    position: relative;
  }

  .value-props-bar__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 25%;
    height: 50%;
    width: 1px;
    background: #e0e0e0;
  }

  .value-props-bar__icon {
    flex-shrink: 0;
    color: #FFB74F;
  }

  .value-props-bar__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .value-props-bar__title {
    font-family: var(--font-heading--family, 'Oswald', sans-serif);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    line-height: 1.2;
    color: #1A1A1A;
  }

  .value-props-bar__subtitle {
    font-family: var(--font-body--family, 'Source Sans Pro', sans-serif);
    font-size: 0.75rem;
    color: #666;
    line-height: 1.3;
  }

  @media screen and (max-width: 989px) {
    .value-props-bar__inner {
      grid-template-columns: repeat(2, 1fr);
    }
    .value-props-bar__item:nth-child(2)::after {
      display: none;
    }
    .value-props-bar__item:nth-child(1),
    .value-props-bar__item:nth-child(2) {
      border-bottom: 1px solid #e0e0e0;
    }
  }

  @media screen and (max-width: 749px) {
    .value-props-bar__item {
      padding: 12px 8px;
      gap: 8px;
    }
    .value-props-bar__icon svg {
      width: 22px;
      height: 22px;
    }
    .value-props-bar__title {
      font-size: 0.6875rem;
    }
    .value-props-bar__subtitle {
      display: none;
    }
  }
</style>
{% endif %}
