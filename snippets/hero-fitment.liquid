<div class="hero-fitment">
  <p class="hero-fitment__label">
    FIND PARTS FOR YOUR VEHICLE
  </p>
  <div class="hero-fitment__icon">
    <svg width="32" height="32" viewBox="0 0 24 24"
      fill="none" stroke="#F5A623" stroke-width="1.5">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
  </div>
  <p class="hero-fitment__sub">
    Select your Year, Make and Model to see
    parts guaranteed to fit your vehicle.
  </p>
  <button class="hero-fitment__btn"
    onclick="document.querySelector(
      '.vehicle-selector__trigger').click()">
    SELECT YOUR VEHICLE
  </button>
  <p class="hero-fitment__guarantee">
    ✓ Guaranteed fitment on every part
  </p>
</div>

<script>
document.addEventListener('DOMContentLoaded',
  function() {
    var h1 = document.querySelector(
      '.hero__content-wrapper h1, ' +
      '.hero h1, ' +
      '.hero__heading'
    );
    if (!h1) return;
    h1.innerHTML = h1.innerHTML.replace(
      'LONG HAUL',
      '<span style="color:#F5A623">LONG HAUL</span>'
    );
  }
);
</script>
