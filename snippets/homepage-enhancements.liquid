<script>
/* Hide duplicate logo container immediately (can't wait for DOMContentLoaded) */
(function() {
  var style = document.createElement('style');
  style.textContent = '.header-logo__image-container--original{display:none!important;width:0!important;height:0!important;overflow:hidden!important}.header-logo__image{display:none!important}';
  document.head.appendChild(style);
})();

/* All DOM manipulation deferred to DOMContentLoaded since this snippet runs in <head> */
document.addEventListener('DOMContentLoaded', function() {
  var path = window.location.pathname;
  var isHome = (path === '/' || path === '');
  var isCollection = path.indexOf('/collections') === 0;

  /* Ensure duplicate logo container is hidden */
  var origContainer = document.querySelector('.header-logo__image-container--original');
  if (origContainer) origContainer.style.setProperty('display', 'none', 'important');

  /* Add body classes for CSS */
  if (isHome) document.body.classList.add('stehlen-home');
  else document.body.classList.add('stehlen-inner');
  if (isCollection) document.body.classList.add('stehlen-collection');

  /* --- HOMEPAGE ONLY --- */
  if (isHome) {
    /* Value props bar after hero */
    (function() {
      if (document.getElementById('stehlen-value-props')) return;
      var mc = document.getElementById('MainContent');
      if (!mc) return;
      /* Insert after LAST section (before footer), not first (after hero) */
      var sections = mc.querySelectorAll('.shopify-section');
      var fs = sections[sections.length - 1];
      if (!fs) return;
      var h = '<div id="stehlen-value-props"><div class="vp-grid">' +
        '<div class="vp-item"><svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg><div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Free Shipping</span><span class="vp-sub">On all orders</span></div></div>' +
        '<div class="vp-item"><svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg><div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Guaranteed Fitment</span><span class="vp-sub">Fits your vehicle or money back</span></div></div>' +
        '<div class="vp-item"><svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4l2 2"></path></svg><div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Manufacturer Warranty</span><span class="vp-sub">On every product</span></div></div>' +
        '<div class="vp-item"><svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg><div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Easy Returns</span><span class="vp-sub">30-day hassle-free returns</span></div></div>' +
      '</div></div>';
      fs.insertAdjacentHTML('afterend', h);
    })();

    /* Collection card title overlays — Lovable style */
    (function() {
      document.querySelectorAll('.collection-card').forEach(function(card) {
        if (card.querySelector('.stehlen-card-title')) return;
        var link = card.querySelector('.collection-card__link');
        if (!link) return;
        var hidden = link.querySelector('.visually-hidden');
        if (!hidden) return;
        var title = hidden.textContent.trim();
        var href = link.getAttribute('href');
        if (!title || !href) return;
        /* Try to get products_count from the collection card data */
        var parentItem = card.closest('[data-products-count]') || card.parentElement;
        var count = parentItem && parentItem.getAttribute('data-products-count') ? parentItem.getAttribute('data-products-count') : '';
        var countText = count ? count + ' PARTS' : 'VIEW ALL';
        var overlay = document.createElement('div');
        overlay.className = 'stehlen-card-title';
        overlay.innerHTML = '<div class="stehlen-card-title__name">' + title + '</div>' +
          '<a href="' + href + '" class="stehlen-card-title__link">' + countText + '</a>';
        var inner = card.querySelector('.collection-card__inner');
        if (inner) { inner.style.position = 'relative'; inner.appendChild(overlay); }
      });
    })();

    /* Shop by Popular Models */
    (function() {
      if (document.getElementById('stehlen-popular-models')) return;
      var mc = document.getElementById('MainContent');
      if (!mc) return;
      var cl = mc.querySelector('.ui-test-collection-list');
      if (!cl) { var ss = mc.querySelectorAll('.shopify-section'); if (ss.length < 2) return; cl = ss[ss.length - 1]; }

      /* Use collection card images as backgrounds for popular models */
      var collImgs = [];
      document.querySelectorAll('.collection-card img').forEach(function(img) {
        if (img.src) collImgs.push(img.src);
      });

      var models = [
        { name: 'Ford F-150', badge: 'MOST POPULAR', sub: 'Truck Parts & Accessories' },
        { name: 'Toyota Tundra', badge: 'TRENDING', sub: 'Truck Parts & Accessories' },
        { name: 'Chevy Silverado', badge: 'BEST SELLERS', sub: 'Truck Parts & Accessories' },
        { name: 'Dodge Charger', badge: 'NEW ARRIVALS', sub: 'Performance & Style Parts' }
      ];
      var cards = models.map(function(m, i) {
        var imgSrc = collImgs[i] || '';
        var imgTag = imgSrc ? '<img class="pm-card-img" src="' + imgSrc + '" alt="' + m.name + ' parts" loading="lazy">' : '';
        return '<a href="/collections/all?filter.p.m.custom.make=' + encodeURIComponent(m.name.split(' ')[0]) + '&filter.p.m.custom.model=' + encodeURIComponent(m.name.split(' ').slice(1).join(' ')) + '" class="pm-card">' +
          imgTag +
          '<div class="pm-card-overlay"></div>' +
          '<div class="pm-badge">' + m.badge + '</div>' +
          '<div class="pm-card-info">' +
            '<div class="pm-card-name">' + m.name + '</div>' +
            '<div class="pm-card-count">' + m.sub + '</div>' +
            '<span class="pm-card-link">View All Parts <span style="font-size:14px">&rarr;</span></span>' +
          '</div></a>';
      }).join('');
      var html = '<div id="stehlen-popular-models"><div class="pm-inner">' +
        '<div class="pm-header"><h2>Shop by Popular Models</h2><p>Find parts specifically designed for your vehicle</p></div>' +
        '<div class="pm-grid">' + cards + '</div></div></div>';
      var ps = cl.closest('.shopify-section') || cl;
      ps.insertAdjacentHTML('afterend', html);
    })();
  }

  /* --- COLLECTION PAGES — force filter sidebar + flex layout (desktop only) --- */
  if (isCollection && window.innerWidth >= 750) {
    setTimeout(function() {
      var sidebar = document.querySelector('.facets-block-wrapper--sidebar');
      if (!sidebar) return;
      sidebar.style.setProperty('display', 'block', 'important');
      sidebar.style.setProperty('width', '220px', 'important');
      sidebar.style.setProperty('min-width', '220px', 'important');
      sidebar.style.setProperty('flex-shrink', '0', 'important');
      ['facets--sidebar', 'facets__form', 'facets__filters-wrapper', 'facets__form-wrapper'].forEach(function(cls) {
        var el = sidebar.querySelector('.' + cls);
        if (el) el.style.setProperty('display', 'block', 'important');
      });
      /* Override Horizon's grid — use two-column CSS grid on wrapper instead of flex
         because flex with 7 children doesn't work reliably */
      var cw = document.querySelector('.collection-wrapper');
      if (cw) {
        /* Remove Horizon's 'grid' class from wrapper too — it forces 14-col subgrid */
        cw.classList.remove('grid');
        /* Also remove gap-style which may add Horizon grid behaviors */
        cw.classList.remove('gap-style');
        cw.style.setProperty('display', 'grid', 'important');
        cw.style.setProperty('grid-template-columns', '220px 1fr', 'important');
        cw.style.setProperty('gap', '28px', 'important');
        cw.style.setProperty('max-width', '1360px', 'important');
        cw.style.setProperty('margin', '0 auto', 'important');
        cw.style.setProperty('padding', '0 40px', 'important');
        /* Hide extra children — only sidebar and product grid should be visible */
        for (var ci = 0; ci < cw.children.length; ci++) {
          var child = cw.children[ci];
          var isSidebar = child.classList.contains('facets-block-wrapper--sidebar');
          var isGrid = child.classList.contains('main-collection-grid');
          if (!isSidebar && !isGrid) {
            child.style.setProperty('display', 'none', 'important');
          }
        }
        /* Place sidebar in column 1, product grid in column 2 */
        sidebar.style.setProperty('grid-column', '1', 'important');
        sidebar.style.setProperty('grid-row', '1', 'important');
      }
      var pg = document.querySelector('.main-collection-grid');
      if (pg) {
        /* Remove Horizon's 'grid' class — it forces a 14-col subgrid that
           overrides even inline styles. Without it, we have full control. */
        pg.classList.remove('grid');
        /* Remove Horizon layout classes that constrain the grid */
        pg.classList.remove('spacing-style');
        pg.classList.remove('collection-wrapper--full-width-on-mobile');
        /* Clear all Horizon CSS custom properties */
        pg.style.removeProperty('--grid-column--desktop');
        pg.style.removeProperty('--grid-column--mobile');
        pg.style.removeProperty('--grid--margin--mobile');
        pg.style.removeProperty('--padding-inline-start');
        pg.style.removeProperty('--padding-inline-end');
        pg.style.setProperty('grid-column', '2', 'important');
        pg.style.setProperty('grid-row', '1', 'important');
        pg.style.setProperty('width', '100%', 'important');
        pg.style.setProperty('max-width', '100%', 'important');
        pg.style.setProperty('min-width', '0', 'important');
        pg.style.setProperty('justify-self', 'stretch', 'important');
        pg.style.setProperty('align-self', 'start', 'important');
        /* Don't set grid on pg — it has Horizon baggage.
           Instead, use block display and let the inner div be the grid. */
        /* Product grid layout is handled by stehlen-theme.css grid rules.
           Do NOT set inline widths on grid items — it breaks CSS grid. */
      }
      /* Open first 3 filter panels */
      var details = sidebar.querySelectorAll('details');
      for (var i = 0; i < details.length && i < 3; i++) details[i].open = true;
    }, 100);
  }
});
</script>
