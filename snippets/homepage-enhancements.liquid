<style>
/* ===== Logo replacement ===== */
.header-logo__image-container {
  position: relative;
}
.header-logo__image {
  visibility: hidden !important;
  width: 0 !important;
  height: 0 !important;
}
.header-logo__image-container--inverse::before,
.header-logo__image-container--original::before {
  content: '';
  display: block;
  width: 180px;
  height: 36px;
  background-image: url({{ 'stehlen-logo.png' | asset_url }});
  background-size: contain;
  background-repeat: no-repeat;
  background-position: left center;
}

/* ===== GLOBAL: Button fixes (button-primary has no bg in color-scheme-5) ===== */
.button-primary,
a.button-primary {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  padding: 14px 32px !important;
  background-color: #FFB74F !important;
  color: #1A1A1A !important;
  border: none !important;
  border-radius: 4px !important;
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 700 !important;
  font-size: 14px !important;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none !important;
  cursor: pointer;
  transition: background-color 0.2s ease, transform 0.2s ease;
  line-height: 1 !important;
  min-height: auto !important;
}
.button-primary:hover,
a.button-primary:hover {
  background-color: #f0a030 !important;
  transform: translateY(-1px);
}
.button-secondary,
a.button-secondary {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  padding: 12px 28px !important;
  background-color: transparent !important;
  color: var(--color-foreground, #1A1A1A) !important;
  border: 2px solid var(--color-foreground, #1A3F22) !important;
  border-radius: 4px !important;
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 600 !important;
  font-size: 13px !important;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none !important;
  cursor: pointer;
  transition: background-color 0.2s ease, color 0.2s ease;
  line-height: 1 !important;
}
.button-secondary:hover,
a.button-secondary:hover {
  background-color: var(--color-foreground, #1A3F22) !important;
  color: #fff !important;
}

/* ===== Hero section fixes ===== */
/* Stronger gradient overlay */
.hero .overlay--gradient {
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.7) 0%,
    rgba(0,0,0,0.45) 35%,
    rgba(0,0,0,0.15) 65%,
    rgba(0,0,0,0) 100%
  ) !important;
}
/* Hero heading — much larger */
.hero__content-wrapper .text-block h1 {
  font-size: clamp(36px, 4vw, 56px) !important;
  font-weight: 700 !important;
  line-height: 1.1 !important;
  letter-spacing: 0.02em;
  text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  color: #fff !important;
}
/* Hero subtitle */
.hero__content-wrapper rte-formatter p,
.hero__content-wrapper .rte p {
  font-size: clamp(14px, 1.2vw, 18px) !important;
  line-height: 1.5 !important;
  text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  color: rgba(255,255,255,0.92) !important;
  max-width: 480px;
}
/* Hero content vertical centering and padding */
.hero__content-wrapper {
  padding: 60px 48px !important;
}

/* ===== Vehicle Selector styling ===== */
.vehicle-selector {
  position: relative;
}
.vehicle-selector__dialog {
  position: fixed;
  left: auto !important;
  bottom: auto !important;
  margin: 0 !important;
  width: 480px !important;
  max-width: calc(100vw - 40px) !important;
  border: none !important;
  border-radius: 0 0 8px 8px !important;
  box-shadow: 0 8px 40px rgba(0,0,0,0.2) !important;
  padding: 0 !important;
  overflow: visible !important;
  background: #fff !important;
  z-index: 999 !important;
}
.vehicle-selector__dialog[open] {
  display: block;
}
.vehicle-selector__dialog::backdrop {
  background: transparent;
}
.vehicle-selector__content {
  padding: 24px !important;
  overflow: visible !important;
}
.vehicle-selector__header {
  display: flex !important;
  justify-content: space-between !important;
  align-items: flex-start !important;
  margin-bottom: 20px !important;
}
.vehicle-selector__title {
  font-family: var(--font-heading--family, Oswald, sans-serif) !important;
  font-size: 20px !important;
  font-weight: 700 !important;
  text-transform: uppercase;
  color: #1A1A1A !important;
  margin: 0 !important;
}
.vehicle-selector__subtitle {
  font-size: 13px !important;
  color: #666 !important;
  margin: 4px 0 0 !important;
}
.vehicle-selector__close {
  background: none !important;
  border: none !important;
  font-size: 24px !important;
  cursor: pointer;
  color: #999;
  padding: 4px 8px !important;
  line-height: 1;
}
.vehicle-selector__close:hover {
  color: #333;
}
.vehicle-selector__fields {
  display: grid !important;
  grid-template-columns: 1fr 1fr 1fr !important;
  gap: 12px !important;
}
.vehicle-selector__label {
  display: block !important;
  font-family: var(--font-heading--family, Oswald, sans-serif) !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #1A1A1A !important;
  margin-bottom: 6px !important;
}
.vehicle-selector__select {
  width: 100% !important;
  padding: 10px 12px !important;
  border: 1px solid #ddd !important;
  border-radius: 4px !important;
  font-size: 14px !important;
  font-family: var(--font-body--family, sans-serif) !important;
  background: #fff !important;
  color: #333 !important;
  appearance: auto !important;
  cursor: pointer;
}
.vehicle-selector__select:focus {
  border-color: #FFB74F !important;
  outline: none !important;
  box-shadow: 0 0 0 2px rgba(255,183,79,0.3) !important;
}
.vehicle-selector__select:disabled {
  background: #f5f5f5 !important;
  color: #999 !important;
  cursor: not-allowed;
}
.vehicle-selector__form button[type="submit"],
.vehicle-selector__submit {
  width: 100% !important;
  margin-top: 16px !important;
  padding: 14px !important;
  background: #FFB74F !important;
  color: #1A1A1A !important;
  border: none !important;
  border-radius: 4px !important;
  font-family: var(--font-heading--family, Oswald, sans-serif) !important;
  font-weight: 700 !important;
  font-size: 14px !important;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  cursor: pointer;
}
/* Hide horizontal scrollbar on vehicle selector */
.vehicle-selector__dialog *::-webkit-scrollbar {
  display: none;
}
.vehicle-selector__dialog * {
  scrollbar-width: none;
}

/* ===== Collection card enhancements ===== */
.collection-card {
  border-radius: 8px !important;
  overflow: hidden;
  position: relative;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.collection-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.15);
}
.collection-card .collection-card__image {
  border-radius: 8px !important;
  overflow: hidden;
}
.collection-card .collection-card__inner {
  position: relative;
}
.collection-card .collection-card__inner::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 55%;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0) 100%);
  pointer-events: none;
  z-index: 2;
  border-radius: 0 0 8px 8px;
}
.stehlen-card-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px;
  z-index: 3;
  color: #fff;
  pointer-events: none;
}
.stehlen-card-title__name {
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 700;
  font-size: 16px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 0 0 6px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
.stehlen-card-title__link {
  font-size: 13px;
  color: #FFB74F;
  font-weight: 600;
  text-decoration: none;
  pointer-events: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: color 0.2s ease;
}
.stehlen-card-title__link:hover {
  color: #ffc978;
}

/* ===== Section spacing fixes ===== */
.section-resource-list {
  padding-top: 48px;
  padding-bottom: 48px;
}
/* More gap between Shop by Category heading and cards */
.section-resource-list .section-resource-list__content {
  margin-bottom: 12px;
}

/* ===== Featured Products polish ===== */
.ui-test-product-list .product-card {
  border-radius: 8px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.ui-test-product-list .product-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.12);
}

/* ===== Value props bar ===== */
#stehlen-value-props {
  background: #fff;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
#stehlen-value-props .vp-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
#stehlen-value-props .vp-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 18px 12px;
  border-right: 1px solid #e0e0e0;
}
#stehlen-value-props .vp-item:last-child {
  border-right: none;
}
#stehlen-value-props .vp-title {
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 600;
  font-size: .8125rem;
  letter-spacing: .03em;
  text-transform: uppercase;
  color: #1A1A1A;
}
#stehlen-value-props .vp-sub {
  font-family: var(--font-body--family, sans-serif);
  font-size: .75rem;
  color: #666;
}

/* ===== Mobile ===== */
@media (max-width: 989px) {
  .hero__content-wrapper {
    padding: 40px 24px !important;
  }
  .vehicle-selector__dialog {
    width: calc(100vw - 32px) !important;
    right: 16px !important;
  }
  .vehicle-selector__fields {
    grid-template-columns: 1fr !important;
  }
  #stehlen-value-props .vp-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  #stehlen-value-props .vp-item:nth-child(2) {
    border-right: none;
  }
  #stehlen-value-props .vp-item:nth-child(1),
  #stehlen-value-props .vp-item:nth-child(2) {
    border-bottom: 1px solid #e0e0e0;
  }
}
@media (max-width: 749px) {
  .hero__content-wrapper {
    padding: 24px 16px !important;
  }
  .stehlen-card-title__name {
    font-size: 13px;
  }
  .stehlen-card-title__link {
    font-size: 11px;
  }
  .stehlen-card-title {
    padding: 12px;
  }
  #stehlen-value-props .vp-item {
    padding: 12px 8px;
    gap: 8px;
  }
  #stehlen-value-props svg {
    width: 22px;
    height: 22px;
  }
  #stehlen-value-props .vp-sub {
    display: none;
  }
}
</style>

<script>
/* Inject value props bar after first section in MainContent */
(function() {
  function injectValueProps() {
    if (document.getElementById('stehlen-value-props')) return;
    var mainContent = document.getElementById('MainContent');
    if (!mainContent) return;
    var firstSection = mainContent.querySelector('.shopify-section');
    if (!firstSection) return;
    var vpHTML = '<div id="stehlen-value-props"><div class="vp-grid">' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Free Shipping</span><span class="vp-sub">On all orders</span></div>' +
      '</div>' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Guaranteed Fitment</span><span class="vp-sub">Fits your vehicle or money back</span></div>' +
      '</div>' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4l2 2"></path></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Manufacturer Warranty</span><span class="vp-sub">On every product</span></div>' +
      '</div>' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Easy Returns</span><span class="vp-sub">30-day hassle-free returns</span></div>' +
      '</div>' +
    '</div></div>';
    firstSection.insertAdjacentHTML('afterend', vpHTML);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectValueProps);
  } else {
    injectValueProps();
  }
  window.addEventListener('load', function() { setTimeout(injectValueProps, 300); });
})();

/* Inject collection card title overlays */
(function() {
  function enhanceCollectionCards() {
    var cards = document.querySelectorAll('.collection-card');
    cards.forEach(function(card) {
      if (card.querySelector('.stehlen-card-title')) return;
      var link = card.querySelector('.collection-card__link');
      if (!link) return;
      var hidden = link.querySelector('.visually-hidden');
      if (!hidden) return;
      var title = hidden.textContent.trim();
      var href = link.getAttribute('href');
      if (!title || !href) return;

      var overlay = document.createElement('div');
      overlay.className = 'stehlen-card-title';
      overlay.innerHTML =
        '<div class="stehlen-card-title__name">' + title + '</div>' +
        '<a href="' + href + '" class="stehlen-card-title__link">View All Parts <span style="font-size:15px">&rarr;</span></a>';

      var inner = card.querySelector('.collection-card__inner');
      if (inner) {
        inner.style.position = 'relative';
        inner.appendChild(overlay);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', enhanceCollectionCards);
  } else {
    enhanceCollectionCards();
  }
  window.addEventListener('load', function() {
    setTimeout(enhanceCollectionCards, 500);
  });
})();
</script>
