<style>
/* ===== Hero gradient fix — stronger overlay for text readability ===== */
.hero .overlay--gradient {
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.65) 0%,
    rgba(0,0,0,0.4) 40%,
    rgba(0,0,0,0.1) 70%,
    rgba(0,0,0,0) 100%
  ) !important;
}

/* Hero text shadow for extra readability */
.hero__content-wrapper .text-block h1,
.hero__content-wrapper .text-block h2 {
  text-shadow: 0 2px 8px rgba(0,0,0,0.5);
}
.hero__content-wrapper rte-formatter p,
.hero__content-wrapper .rte p {
  text-shadow: 0 1px 4px rgba(0,0,0,0.4);
}

/* ===== Collection card enhancements ===== */
.collection-card {
  border-radius: 8px !important;
  overflow: hidden;
  position: relative;
}

.collection-card .collection-card__image {
  border-radius: 8px !important;
  overflow: hidden;
}

/* Dark gradient overlay on collection card images */
.collection-card .collection-card__inner {
  position: relative;
}

.collection-card .collection-card__inner::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0) 100%);
  pointer-events: none;
  z-index: 2;
  border-radius: 0 0 8px 8px;
}

/* Title overlay positioned at bottom of card */
.stehlen-card-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  z-index: 3;
  color: #fff;
  pointer-events: none;
}

.stehlen-card-title__name {
  font-family: var(--font-heading-family, 'Oswald', sans-serif);
  font-weight: 700;
  font-size: 18px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 0 0 4px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
}

.stehlen-card-title__link {
  font-size: 13px;
  color: #FFB74F;
  font-weight: 600;
  text-decoration: none;
  pointer-events: auto;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.stehlen-card-title__link:hover {
  color: #ffc978;
  text-decoration: underline;
}

/* Card hover lift effect */
.collection-card {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.collection-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.15);
}

/* ===== Featured Products section polish ===== */
.ui-test-product-list .product-card {
  border-radius: 8px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.ui-test-product-list .product-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.12);
}

/* ===== Value props bar ===== */
#stehlen-value-props {
  background: #fff;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
#stehlen-value-props .vp-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
#stehlen-value-props .vp-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 18px 12px;
  border-right: 1px solid #e0e0e0;
}
#stehlen-value-props .vp-item:last-child {
  border-right: none;
}
#stehlen-value-props .vp-title {
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 600;
  font-size: .8125rem;
  letter-spacing: .03em;
  text-transform: uppercase;
  color: #1A1A1A;
}
#stehlen-value-props .vp-sub {
  font-family: var(--font-body--family, sans-serif);
  font-size: .75rem;
  color: #666;
}

/* ===== Mobile adjustments ===== */
@media (max-width: 989px) {
  #stehlen-value-props .vp-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  #stehlen-value-props .vp-item:nth-child(2) {
    border-right: none;
  }
  #stehlen-value-props .vp-item:nth-child(1),
  #stehlen-value-props .vp-item:nth-child(2) {
    border-bottom: 1px solid #e0e0e0;
  }
}
@media (max-width: 749px) {
  .stehlen-card-title__name {
    font-size: 14px;
  }
  .stehlen-card-title__link {
    font-size: 12px;
  }
  .stehlen-card-title {
    padding: 10px;
  }
  #stehlen-value-props .vp-item {
    padding: 12px 8px;
    gap: 8px;
  }
  #stehlen-value-props svg {
    width: 22px;
    height: 22px;
  }
  #stehlen-value-props .vp-sub {
    display: none;
  }
}
</style>

<script>
/* Inject value props bar after first section in MainContent */
(function() {
  function injectValueProps() {
    if (document.getElementById('stehlen-value-props')) return;
    var mainContent = document.getElementById('MainContent');
    if (!mainContent) return;
    var firstSection = mainContent.querySelector('.shopify-section');
    if (!firstSection) return;
    var vpHTML = '<div id="stehlen-value-props"><div class="vp-grid">' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Free Shipping</span><span class="vp-sub">On all orders</span></div>' +
      '</div>' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Guaranteed Fitment</span><span class="vp-sub">Fits your vehicle or money back</span></div>' +
      '</div>' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4l2 2"></path></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Manufacturer Warranty</span><span class="vp-sub">On every product</span></div>' +
      '</div>' +
      '<div class="vp-item">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>' +
        '<div style="display:flex;flex-direction:column;gap:2px"><span class="vp-title">Easy Returns</span><span class="vp-sub">30-day hassle-free returns</span></div>' +
      '</div>' +
    '</div></div>';
    firstSection.insertAdjacentHTML('afterend', vpHTML);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectValueProps);
  } else {
    injectValueProps();
  }
  window.addEventListener('load', function() { setTimeout(injectValueProps, 300); });
})();

/* Inject collection card title overlays */
(function() {
  function enhanceCollectionCards() {
    var cards = document.querySelectorAll('.collection-card');
    cards.forEach(function(card) {
      if (card.querySelector('.stehlen-card-title')) return;
      var link = card.querySelector('.collection-card__link');
      if (!link) return;
      var hidden = link.querySelector('.visually-hidden');
      if (!hidden) return;
      var title = hidden.textContent.trim();
      var href = link.getAttribute('href');
      if (!title || !href) return;

      var overlay = document.createElement('div');
      overlay.className = 'stehlen-card-title';
      overlay.innerHTML =
        '<div class="stehlen-card-title__name">' + title + '</div>' +
        '<a href="' + href + '" class="stehlen-card-title__link">View All Parts <span style="font-size:16px">&rarr;</span></a>';

      var inner = card.querySelector('.collection-card__inner');
      if (inner) {
        inner.style.position = 'relative';
        inner.appendChild(overlay);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', enhanceCollectionCards);
  } else {
    enhanceCollectionCards();
  }
  /* Re-run after Shopify section rendering */
  window.addEventListener('load', function() {
    setTimeout(enhanceCollectionCards, 500);
  });
})();
</script>
