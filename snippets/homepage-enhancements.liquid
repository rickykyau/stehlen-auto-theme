{% comment %}v20260314-category-grid-v2{% endcomment %}
<style>
/* ==========================================================================
   STEHLEN AUTO — Global UI Overrides
   Professional storefront styling for trust, usability, and conversions
   ========================================================================== */

/* ===== 1. ANNOUNCEMENT + HEADER UNIFICATION ===== */
.stehlen-announcements {
  background: #1A1200 !important;
  border-bottom: none !important;
}
#header-group { margin-top: 0; }
#header-group > .shopify-section { background: transparent !important; }
.header,
.header-main,
[data-section-type="header"] {
  background: #1a1a1a !important;
}
.header__wrapper,
.header-main__wrapper {
  display: flex !important;
  align-items: center !important;
  min-height: 60px;
}

/* ===== 2. LOGO REPLACEMENT + CENTERING ===== */
.header-logo__image-container {
  display: flex !important;
  align-items: center !important;
}
/* Hide the original (light-bg) logo container — header is dark */
.header-logo__image-container--original {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  overflow: hidden !important;
}
.header-logo__image {
  display: none !important;
  visibility: hidden !important;
  width: 0 !important;
  height: 0 !important;
  position: absolute !important;
  overflow: hidden !important;
}
.header-logo__image-container--inverse::before {
  content: '';
  display: block;
  width: 180px;
  height: 36px;
  background-image: url({{ 'stehlen-logo.png' | asset_url }});
  background-size: contain;
  background-repeat: no-repeat;
  background-position: left center;
  flex-shrink: 0;
}
.header-logo {
  display: flex !important;
  align-items: center !important;
}

/* ===== 3. INNER PAGE — prevent sticky header from covering content ===== */
{% if template.name != 'index' %}
#MainContent {
  padding-top: 80px !important;
}
/* Hide value props bar on all non-homepage pages */
.value-props-section,
.value-props-bar,
#stehlen-value-props,
.shopify-section:has(.value-props-bar) {
  display: none !important;
}
{% endif %}

/* ===== 4. BUTTONS — global fix for missing button styles ===== */
.button-primary,
a.button-primary {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  padding: 14px 32px !important;
  background-color: #FFB74F !important;
  color: #1A1A1A !important;
  border: none !important;
  border-radius: 4px !important;
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 700 !important;
  font-size: 14px !important;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none !important;
  cursor: pointer;
  transition: background-color 0.2s ease, transform 0.2s ease;
  line-height: 1 !important;
  min-height: auto !important;
}
.button-primary:hover,
a.button-primary:hover {
  background-color: #e09a35 !important;
  transform: translateY(-1px);
}
.button-secondary,
a.button-secondary {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  padding: 12px 28px !important;
  background-color: transparent !important;
  color: #F5A623 !important;
  border: none !important;
  border-radius: 0 !important;
  font-family: 'Barlow Condensed', sans-serif !important;
  font-weight: 700 !important;
  font-size: 13px !important;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none !important;
  cursor: pointer;
  transition: all 0.2s ease;
  line-height: 1 !important;
}
.button-secondary:hover,
a.button-secondary:hover {
  background-color: var(--color-foreground, #1A3F22) !important;
  color: #fff !important;
}

/* ===== 4b. ZERO BORDER RADIUS ON ALL BUTTONS ===== */
button.stehlen-card-cta__cart,
.stehlen-card-cta__cart,
button.quick-add__button,
.quick-add__button,
.quick-add__button--add,
button[name="add"],
.product-form__submit,
form[action*="cart"] button[type="submit"],
form[action*="cart"] button.stehlen-card-cta__cart,
.stehlen-card-cta form button[type="submit"] {
  border-radius: 0 !important;
}
/* Hide light grey footer trust bar */
#stehlen-footer-trust,
.stehlen-footer-trust {
  display: none !important;
}
/* Footer border-radius — social icons, input, button */
.stehlen-footer__social a,
.stehlen-footer a[href*="facebook"],
.stehlen-footer a[href*="instagram"],
.stehlen-footer a[href*="tiktok"],
.stehlen-footer a[href*="youtube"],
.stehlen-footer a[href*="pinterest"] {
  border-radius: 0 !important;
}
.stehlen-footer__input,
.stehlen-footer input,
.stehlen-footer__signup-btn,
.stehlen-footer button {
  border-radius: 0 !important;
}

/* ===== 5. HERO SECTION ===== */
.hero .overlay--gradient {
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.72) 0%,
    rgba(0,0,0,0.45) 35%,
    rgba(0,0,0,0.12) 65%,
    rgba(0,0,0,0) 100%
  ) !important;
}
.hero__content-wrapper .text-block h1 {
  font-size: clamp(36px, 4vw, 56px) !important;
  font-weight: 700 !important;
  line-height: 1.1 !important;
  letter-spacing: 0.02em;
  text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  color: #fff !important;
}
.hero__content-wrapper rte-formatter p,
.hero__content-wrapper .rte p {
  font-size: clamp(14px, 1.2vw, 18px) !important;
  line-height: 1.5 !important;
  text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  color: rgba(255,255,255,0.92) !important;
  max-width: 480px;
}
.hero__content-wrapper {
  padding: 60px 48px !important;
}

/* ===== 6. VEHICLE SELECTOR — dark theme dropdown ===== */
.vehicle-selector {
  position: relative;
  display: flex !important;
  align-items: center !important;
}
header-actions {
  display: flex !important;
  align-items: center !important;
}
.vehicle-selector__trigger {
  display: flex !important;
  align-items: center !important;
  gap: 8px;
  white-space: nowrap;
  align-self: center !important;
}

/* --- Dialog container --- */
.vehicle-selector__dialog,
dialog.vehicle-selector__dialog {
  position: fixed;
  left: auto !important;
  bottom: auto !important;
  margin: 0 !important;
  width: 540px !important;
  max-width: calc(100vw - 20px) !important;
  border: none !important;
  border-radius: 0 0 12px 12px !important;
  box-shadow: 0 16px 56px rgba(0,0,0,0.5) !important;
  padding: 0 !important;
  overflow: visible !important;
  background: #1a1a1a !important;
  z-index: 9999 !important;
}
.vehicle-selector__dialog[open] {
  display: block;
  animation: vsSlideDown 0.22s ease-out;
}
@keyframes vsSlideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}
.vehicle-selector__dialog::backdrop {
  background: rgba(0,0,0,0.3);
}

/* --- Inner content --- */
.vehicle-selector__content {
  padding: 28px 32px 32px !important;
  overflow: visible !important;
}

/* --- Header row --- */
.vehicle-selector__header {
  display: flex !important;
  justify-content: space-between !important;
  align-items: flex-start !important;
  margin-bottom: 24px !important;
}
.vehicle-selector__title {
  font-family: var(--font-heading--family, Montserrat, sans-serif) !important;
  font-size: 16px !important;
  font-weight: 700 !important;
  text-transform: uppercase;
  color: #fff !important;
  margin: 0 !important;
  letter-spacing: 0.06em;
}
.vehicle-selector__subtitle {
  font-size: 13px !important;
  color: rgba(255,255,255,0.45) !important;
  margin: 6px 0 0 !important;
}

/* --- Close button — override theme's orange circle --- */
.vehicle-selector__close,
.vehicle-selector__dialog .vehicle-selector__close,
button.vehicle-selector__close,
.vehicle-selector__dialog button {
  -webkit-appearance: none !important;
  appearance: none !important;
}
.vehicle-selector__close,
.vehicle-selector__dialog .vehicle-selector__close,
button.vehicle-selector__close {
  background: none !important;
  background-color: transparent !important;
  background-image: none !important;
  border: none !important;
  border-color: transparent !important;
  outline: none !important;
  box-shadow: none !important;
  font-size: 26px !important;
  cursor: pointer;
  color: rgba(255,255,255,0.5) !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 1;
  width: 36px;
  height: 36px;
  min-width: 0 !important;
  min-height: 0 !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  border-radius: 6px !important;
  transition: all 0.15s ease;
}
.vehicle-selector__close:hover,
.vehicle-selector__close:focus,
button.vehicle-selector__close:hover,
button.vehicle-selector__close:focus {
  color: #fff !important;
  background: rgba(255,255,255,0.08) !important;
  background-color: rgba(255,255,255,0.08) !important;
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
}

/* --- Labels — show them for clarity --- */
.vehicle-selector__label {
  display: block !important;
  font-family: var(--font-heading--family, Montserrat, sans-serif) !important;
  font-size: 11px !important;
  font-weight: 600 !important;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5) !important;
  margin-bottom: 8px !important;
}

/* --- Fields grid --- */
.vehicle-selector__fields {
  display: grid !important;
  grid-template-columns: 1fr 1fr 1fr !important;
  gap: 16px !important;
  align-items: end;
  margin-bottom: 20px !important;
}
.vehicle-selector__field--action {
  grid-column: 1 / -1;
}

/* --- Select dropdowns — dark style with visible text --- */
.vehicle-selector__select,
.vehicle-selector__dialog select {
  width: 100% !important;
  padding: 13px 36px 13px 14px !important;
  border: 1.5px solid rgba(255,255,255,0.18) !important;
  border-radius: 8px !important;
  font-size: 14px !important;
  font-family: var(--font-body--family, sans-serif) !important;
  background: #2c2c2c !important;
  color: rgba(255,255,255,0.85) !important;
  appearance: auto !important;
  cursor: pointer;
  transition: border-color 0.15s ease, background-color 0.15s ease;
}
.vehicle-selector__select:focus,
.vehicle-selector__dialog select:focus {
  border-color: #FFB74F !important;
  outline: none !important;
  box-shadow: 0 0 0 3px rgba(255,183,79,0.15) !important;
  background: #363636 !important;
}
.vehicle-selector__select:disabled,
.vehicle-selector__dialog select:disabled {
  background: #232323 !important;
  color: rgba(255,255,255,0.3) !important;
  cursor: not-allowed;
  border-color: rgba(255,255,255,0.08) !important;
}
.vehicle-selector__select option {
  background: #2c2c2c;
  color: #fff;
}

/* --- GO button — full width, prominent --- */
button.vehicle-selector__go,
.vehicle-selector__dialog button.vehicle-selector__go,
.vehicle-selector__dialog .vehicle-selector__go {
  width: 100% !important;
  padding: 14px 28px !important;
  background-color: #FFB74F !important;
  background: #FFB74F !important;
  color: #1A1A1A !important;
  border: none !important;
  border-radius: 8px !important;
  font-family: var(--font-heading--family, Montserrat, sans-serif) !important;
  font-weight: 700 !important;
  font-size: 15px !important;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.1s ease;
  white-space: nowrap;
  -webkit-appearance: none !important;
  appearance: none !important;
  box-shadow: none !important;
}
button.vehicle-selector__go:hover:not(:disabled),
.vehicle-selector__dialog button.vehicle-selector__go:hover:not(:disabled) {
  background-color: #e09a35 !important;
  background: #e09a35 !important;
  transform: translateY(-1px);
}
button.vehicle-selector__go:disabled,
.vehicle-selector__dialog button.vehicle-selector__go:disabled {
  opacity: 0.35;
  cursor: not-allowed;
  transform: none;
}

/* --- Saved vehicle bar — gold accent, not green --- */
/* Kill ALL theme defaults inside saved bar */
.vehicle-selector__saved *,
.vehicle-selector__dialog .vehicle-selector__saved * {
  margin: 0 !important;
  padding: 0 !important;
  line-height: 1 !important;
  box-sizing: border-box !important;
}
.vehicle-selector__saved,
.vehicle-selector__dialog .vehicle-selector__saved {
  margin-top: 20px !important;
  margin-bottom: 0 !important;
  padding: 0 18px !important;
  background: rgba(255,183,79,0.08);
  border: 1px solid rgba(255,183,79,0.25);
  border-radius: 8px;
  display: flex;
  flex-direction: row !important;
  justify-content: space-between;
  align-items: center !important;
  height: 52px;
}
.vehicle-selector__saved-info,
.vehicle-selector__dialog .vehicle-selector__saved-info {
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  color: #fff !important;
  font-size: 14px !important;
  font-weight: 600 !important;
}
.vehicle-selector__saved-icon {
  color: #FFB74F !important;
  font-weight: 700 !important;
  margin-right: 10px !important;
  font-size: 16px !important;
}
.vehicle-selector__clear,
button.vehicle-selector__clear,
.vehicle-selector__saved button.vehicle-selector__clear {
  background: none !important;
  background-color: transparent !important;
  border: 1px solid rgba(255,255,255,0.25) !important;
  border-radius: 6px !important;
  padding: 8px 16px !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  color: rgba(255,255,255,0.7) !important;
  cursor: pointer;
  transition: all 0.15s ease;
  -webkit-appearance: none !important;
  appearance: none !important;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  box-shadow: none !important;
  flex-shrink: 0;
}
.vehicle-selector__clear:hover,
button.vehicle-selector__clear:hover {
  border-color: rgba(255,255,255,0.5) !important;
  color: #fff !important;
  background-color: rgba(255,255,255,0.06) !important;
}
.vehicle-selector__dialog *::-webkit-scrollbar { display: none; }
.vehicle-selector__dialog * { scrollbar-width: none; }

/* ===== 6b. COLLECTION CARD GRID SPACING ===== */
.resource-list.resource-list--grid {
  gap: 8px !important;
}

/* ===== 6c. CONSISTENT SECTION HEADINGS ===== */
.section-resource-list h2,
#stehlen-popular-models .pm-header h2,
.section-resource-list .text-block h2 {
  font-family: var(--font-heading--family, Montserrat, sans-serif) !important;
  font-weight: 700 !important;
  font-size: 32px !important;
  text-transform: uppercase !important;
  letter-spacing: 0.04em !important;
  color: #222 !important;
  margin-bottom: 8px !important;
}

/* ===== 7. COLLECTION CARDS — Lovable edge-to-edge category grid ===== */

/* Section wrapper — remove all padding/gap for seamless grid */
.ui-test-collection-list .section-resource-list {
  padding: 0 !important;
}
.ui-test-collection-list .section-resource-list__content {
  margin-bottom: 0 !important;
}
.ui-test-collection-list .resource-list {
  gap: 0 !important;
}
.ui-test-collection-list .resource-list__item {
  border-right: 1px solid hsl(220 8% 25%);
  border-bottom: 1px solid hsl(220 8% 25%);
}
.ui-test-collection-list .resource-list__item:nth-child(4n) {
  border-right: none;
}
/* Remove Horizon spacing/gap utility styles */
.ui-test-collection-list .gap-style {
  --gap: 0px !important;
  --columns-gap: 0px !important;
  --rows-gap: 0px !important;
  gap: 0 !important;
}
.ui-test-collection-list .spacing-style {
  --padding-block-start: 0px !important;
  --padding-block-end: 0px !important;
  padding: 0 !important;
}

/* Card — no border-radius, no background, no borders, no lift */
.collection-card {
  border-radius: 0 !important;
  overflow: hidden;
  position: relative;
  background: transparent !important;
  border: none !important;
}
.collection-card:hover {
  transform: none !important;
  box-shadow: none !important;
}
.collection-card,
.collection-card .border-style {
  --color-border: transparent !important;
  border: none !important;
  border-radius: 0 !important;
}

/* Image — fill entire card, dimmed like Lovable */
.collection-card .collection-card__image {
  border-radius: 0 !important;
  overflow: hidden;
}
.collection-card .collection-card__image img {
  opacity: 0.5 !important;
  transition: opacity 500ms, transform 500ms !important;
}
.collection-card:hover .collection-card__image img {
  opacity: 0.7 !important;
  transform: scale(1.05) !important;
}

/* Inner container — relative for overlay positioning */
.collection-card .collection-card__inner {
  position: relative;
  aspect-ratio: 4/3;
}
.collection-card .collection-card__inner img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}

/* Gradient overlay — from background color (dark) to transparent */
.collection-card .collection-card__inner::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, hsl(220 15% 8%) 0%, transparent 60%);
  pointer-events: none;
  z-index: 2;
  border-radius: 0;
}

/* Title overlay — bottom-left positioned */
.stehlen-card-title {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 16px;
  z-index: 3;
  color: #fff;
  pointer-events: none;
}
.stehlen-card-title__name {
  font-family: var(--lov-font-display, 'Barlow Condensed', sans-serif);
  font-weight: 600;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 4px;
  color: hsl(220 10% 96%);
}
.stehlen-card-title__link {
  font-size: 10px;
  color: #F5A623;
  font-family: var(--lov-font-display, 'Barlow Condensed', sans-serif);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  pointer-events: auto;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: color 0.2s ease;
}
.stehlen-card-title__link:hover { color: #FFB93A; }

/* Hide Horizon's default collection card content area (title below image) */
.collection-card .collection-card__content,
.collection-card .collection-card__text-content {
  display: none !important;
}

/* ===== 8. HOMEPAGE SECTION SPACING — breathing room ===== */
{% if template.name == 'index' %}
#MainContent > .shopify-section + .shopify-section {
  border-top: 1px solid rgba(0,0,0,0.06);
}
/* Non-collection sections keep padding */
.section-resource-list:not(.ui-test-collection-list .section-resource-list) {
  padding-top: 56px !important;
  padding-bottom: 56px !important;
}
.section-resource-list:not(.ui-test-collection-list .section-resource-list) .section-resource-list__content {
  margin-bottom: 28px;
}
/* Collection list section — Lovable header bar with border */
.ui-test-collection-list .section-resource-list__content {
  padding: 24px 16px 24px 32px !important;
  margin: 0 !important;
  border-bottom: 1px solid hsl(220 8% 25%);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ui-test-collection-list .section-resource-list__content h2 {
  font-family: var(--lov-font-display, 'Barlow Condensed', sans-serif) !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  letter-spacing: 0.15em !important;
  color: hsl(220 8% 55%) !important;
  margin: 0 !important;
  padding: 0 !important;
}
{% endif %}

/* ===== 9. PRODUCT CARD — Lovable dark theme ===== */
.ui-test-product-list .product-card {
  border-radius: 0 !important;
  overflow: hidden;
}
/* Ensure product title text is light on dark card */
.ui-test-product-list .product-card .text-block,
.ui-test-product-list .product-card .text-block a,
.ui-test-product-list .product-card .typography-style,
.ui-test-product-list .product-card .typography-style a {
  color: hsl(220 10% 86%) !important;
}
/* Featured Products section heading — light on dark */
.ui-test-product-list .section-resource-list__header .text-block,
.ui-test-product-list .section-resource-list__header h2,
.ui-test-product-list .section-resource-list__header h3,
.ui-test-product-list .section-resource-list__content .text-block,
.ui-test-product-list .section-resource-list__content h2,
.ui-test-product-list .section-resource-list__content h3 {
  color: #f4f4f6 !important;
  font-family: 'Barlow Condensed', sans-serif !important;
  font-size: 20px !important;
  font-weight: 800 !important;
  letter-spacing: 2px !important;
  text-transform: uppercase !important;
}

/* ===== 10. VALUE PROPS BAR ===== */
#stehlen-value-props {
  background: #fff;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
  padding: 6px 0;
}
#stehlen-value-props .vp-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
#stehlen-value-props .vp-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 18px 12px;
  border-right: 1px solid #e0e0e0;
}
#stehlen-value-props .vp-item:last-child { border-right: none; }
#stehlen-value-props .vp-title {
  font-family: var(--font-heading--family, Oswald, sans-serif);
  font-weight: 600;
  font-size: .8125rem;
  letter-spacing: .03em;
  text-transform: uppercase;
  color: #1A1A1A;
}
#stehlen-value-props .vp-sub {
  font-family: var(--font-body--family, sans-serif);
  font-size: .75rem;
  color: #666;
}

/* ===== 11. SHOP BY POPULAR MODELS ===== */
#stehlen-popular-models {
  background: #f8f8f8;
  padding: 56px 0;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
#stehlen-popular-models .pm-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
#stehlen-popular-models .pm-header {
  text-align: center;
  margin-bottom: 36px;
}
#stehlen-popular-models .pm-header h2 {
  margin: 0 0 8px;
}
#stehlen-popular-models .pm-header p {
  font-family: var(--font-body--family, sans-serif);
  font-size: 15px;
  color: #666;
  margin: 0;
}
#stehlen-popular-models .pm-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
#stehlen-popular-models .pm-card {
  position: relative;
  border-radius: 10px;
