{% comment %}
  PDP Enhancements — Fitment badge, tabbed content, return policy, incentive CTA
  Injected on product pages via JavaScript DOM manipulation
{% endcomment %}

{% if template.name == 'product' %}
<style>
  /* Fitment Badge */
  .stehlen-fitment { margin: 16px 0; }
  .stehlen-fitment__badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 4px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.875rem;
    font-weight: 500;
  }
  .stehlen-fitment__badge--fits { background: #1A3F22; color: #fff; }
  .stehlen-fitment__badge--nofit { background: #FF4E4E; color: #fff; }
  .stehlen-fitment__badge--check { background: #f5f5f5; color: #333; border: 1px solid #e0e0e0; }
  .stehlen-fitment__badge svg { flex-shrink: 0; }
  .stehlen-fitment__badge strong { font-weight: 700; }

  /* Tabbed Content */
  .stehlen-tabs { margin: 40px 0; max-width: 1200px; margin-left: auto; margin-right: auto; padding: 0 20px; }
  .stehlen-tabs__nav {
    display: flex;
    gap: 0;
    border-bottom: 2px solid #e0e0e0;
    margin-bottom: 24px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .stehlen-tabs__btn {
    padding: 12px 24px;
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    color: #666;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .stehlen-tabs__btn:hover { color: #1A1A1A; }
  .stehlen-tabs__btn--active {
    color: #1A1A1A;
    border-bottom-color: #FFB74F;
  }
  .stehlen-tabs__panel { display: none; }
  .stehlen-tabs__panel--active { display: block; }
  .stehlen-tabs__panel h3 {
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: #1A1A1A;
  }
  .stehlen-tabs__panel p, .stehlen-tabs__panel li {
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #444;
  }
  .stehlen-tabs__panel ul { padding-left: 20px; margin: 12px 0; }
  .stehlen-tabs__panel li { margin-bottom: 8px; }

  /* Return Policy / Warranty */
  .stehlen-policy {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin: 16px 0 0;
  }
  .stehlen-policy__item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    background: #f8f8f8;
    border-radius: 4px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.75rem;
    color: #444;
    line-height: 1.3;
  }
  .stehlen-policy__item svg { flex-shrink: 0; color: #1A3F22; }

  @media screen and (max-width: 749px) {
    .stehlen-policy { grid-template-columns: 1fr; }
    .stehlen-tabs__btn { padding: 10px 16px; font-size: 0.8125rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Only run on product pages
    if (!document.querySelector('.product-information')) return;

    // ==========================================
    // 1. FITMENT BADGE — Insert after product title
    // ==========================================
    var productDetails = document.querySelector('.product-details');
    if (!productDetails) return;

    // Get product tags from Liquid (injected below)
    var productTagsEl = document.getElementById('stehlen-product-tags-data');
    var productTags = [];
    if (productTagsEl) {
      try { productTags = JSON.parse(productTagsEl.textContent); } catch(e) {}
    }

    // Get saved vehicle
    var savedVehicle = null;
    try {
      var sv = localStorage.getItem('stehlen-vehicle') || localStorage.getItem('stehlen_vehicle');
      if (sv) savedVehicle = JSON.parse(sv);
    } catch(e) {}

    // Build fitment badge
    var fitmentHtml = '<div class="stehlen-fitment">';
    if (savedVehicle && savedVehicle.year && savedVehicle.make && savedVehicle.model) {
      var vName = savedVehicle.year + ' ' + savedVehicle.make + ' ' + savedVehicle.model;
      var lTags = productTags.map(function(t) { return t.toLowerCase(); });
      var fitsMake = lTags.some(function(t) { return t === 'make:' + savedVehicle.make.toLowerCase(); });
      var fitsModel = lTags.some(function(t) { return t === 'model:' + savedVehicle.model.toLowerCase(); });
      var fitsYear = lTags.some(function(t) { return t === 'year:' + savedVehicle.year; });

      if (fitsMake && fitsModel && fitsYear) {
        fitmentHtml += '<div class="stehlen-fitment__badge stehlen-fitment__badge--fits">' +
          '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>' +
          '<span>This Fits Your <strong>' + vName + '</strong></span></div>';
      } else if (productTags.length === 0) {
        fitmentHtml += '<div class="stehlen-fitment__badge stehlen-fitment__badge--check">' +
          '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>' +
          '<span>Select your vehicle to verify fitment</span></div>';
      } else {
        fitmentHtml += '<div class="stehlen-fitment__badge stehlen-fitment__badge--nofit">' +
          '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>' +
          '<span>May Not Fit Your <strong>' + vName + '</strong></span></div>';
      }
    } else {
      fitmentHtml += '<div class="stehlen-fitment__badge stehlen-fitment__badge--check">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>' +
        '<span>Select your vehicle to verify fitment</span></div>';
    }
    fitmentHtml += '</div>';

    // Insert fitment badge after the first group (title/price)
    var firstGroup = productDetails.querySelector('.product-details > *:first-child');
    if (firstGroup) {
      firstGroup.insertAdjacentHTML('afterend', fitmentHtml);
    }

    // ==========================================
    // 2. RETURN/WARRANTY POLICY ICONS — Insert after buy buttons
    // ==========================================
    var buyButtons = productDetails.querySelector('[data-testid="buy-buttons"], .buy-buttons, buy-buttons-component');
    if (!buyButtons) {
      // Try broader search
      buyButtons = productDetails.querySelector('add-to-cart-component, .shopify-payment-button');
      if (buyButtons) buyButtons = buyButtons.closest('div');
    }

    var policyHtml = '<div class="stehlen-policy">' +
      '<div class="stehlen-policy__item"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>Free Shipping</div>' +
      '<div class="stehlen-policy__item"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>30-Day Returns</div>' +
      '<div class="stehlen-policy__item"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4l2 2"></path></svg>Manufacturer Warranty</div>' +
      '</div>';

    if (buyButtons) {
      buyButtons.insertAdjacentHTML('afterend', policyHtml);
    }

    // ==========================================
    // 3. TABBED CONTENT — Insert below the product info section
    // ==========================================
    var productSection = document.querySelector('.product-information');
    if (productSection) {
      // Get description from Liquid-injected data (most reliable)
      var descContent = '';
      var descDataEl = document.getElementById('stehlen-product-desc-data');
      if (descDataEl) {
        try { descContent = JSON.parse(descDataEl.textContent) || ''; } catch(e) {}
      }
      // Fallback: try to find description in DOM
      if (!descContent) {
        var descEl = productDetails.querySelector('[data-testid="product-description"], .product-description, .typography-style, .rte');
        if (descEl && descEl.innerHTML.length > 50) {
          descContent = descEl.innerHTML;
        }
      }
      // If we found description content in the DOM, hide the original to avoid duplication
      if (descContent) {
        var origDesc = productDetails.querySelector('.product-description, [data-testid="product-description"], .typography-style');
        if (origDesc && origDesc.innerHTML.length > 50) {
          origDesc.style.display = 'none';
        }
      }

      // Always add tabs
      {
        // Parse description into sections if it has headers
        var overviewContent = descContent || '<p>Product details coming soon.</p>';
        var specsContent = '<h3>Product Specifications</h3><ul><li>Brand: Stehlen Auto</li><li>Condition: Brand New</li><li>Direct Fit - No Modification Required</li></ul>';

        // Try to extract structured sections from description
        if (descContent) {
          var tempDiv = document.createElement('div');
          tempDiv.innerHTML = descContent;
          var sections = {};
          var currentSection = 'overview';
          var currentContent = [];

          // Walk through child nodes looking for headers that indicate sections
          Array.from(tempDiv.children).forEach(function(el) {
            var text = (el.textContent || '').trim().toUpperCase();
            if (text.match(/^(PRODUCT\s+)?OVERVIEW/) || text.match(/^DESCRIPTION/)) {
              if (currentContent.length) sections[currentSection] = currentContent.join('');
              currentSection = 'overview';
              currentContent = [];
            } else if (text.match(/^FEATURES?/) || text.match(/^KEY\s+FEATURES/)) {
              if (currentContent.length) sections[currentSection] = currentContent.join('');
              currentSection = 'features';
              currentContent = [];
            } else if (text.match(/^SPECIFICATIONS?/) || text.match(/^SPECS?/) || text.match(/^TECHNICAL/)) {
              if (currentContent.length) sections[currentSection] = currentContent.join('');
              currentSection = 'specs';
              currentContent = [];
            } else if (text.match(/^VEHICLE\s+FITMENT/) || text.match(/^COMPATIBILITY/) || text.match(/^FITS/)) {
              if (currentContent.length) sections[currentSection] = currentContent.join('');
              currentSection = 'fitment';
              currentContent = [];
            } else {
              currentContent.push(el.outerHTML);
            }
          });
          if (currentContent.length) sections[currentSection] = currentContent.join('');

          // Build overview from overview + features + fitment
          if (sections.overview || sections.features || sections.fitment) {
            overviewContent = '';
            if (sections.overview) overviewContent += sections.overview;
            if (sections.features) overviewContent += '<h3>Features</h3>' + sections.features;
            if (sections.fitment) overviewContent += '<h3>Vehicle Fitment</h3>' + sections.fitment;
          }
          if (sections.specs) {
            specsContent = '<h3>Product Specifications</h3>' + sections.specs;
          }
        }

        var tabsHtml = '<div class="stehlen-tabs">' +
          '<div class="stehlen-tabs__nav">' +
          '<button class="stehlen-tabs__btn stehlen-tabs__btn--active" data-tab="overview">Overview</button>' +
          '<button class="stehlen-tabs__btn" data-tab="specs">Specifications</button>' +
          '<button class="stehlen-tabs__btn" data-tab="shipping">Shipping & Returns</button>' +
          '<button class="stehlen-tabs__btn" data-tab="warranty">Warranty</button>' +
          '</div>' +
          '<div class="stehlen-tabs__panel stehlen-tabs__panel--active" data-panel="overview">' +
          overviewContent +
          '</div>' +
          '<div class="stehlen-tabs__panel" data-panel="specs">' +
          specsContent +
          '</div>' +
          '<div class="stehlen-tabs__panel" data-panel="shipping">' +
          '<h3>Shipping Information</h3>' +
          '<ul>' +
          '<li>Free standard shipping on all orders</li>' +
          '<li>Processing time: 1-2 business days</li>' +
          '<li>Estimated delivery: 3-7 business days</li>' +
          '<li>Tracking number provided via email</li>' +
          '</ul>' +
          '<h3>Return Policy</h3>' +
          '<ul>' +
          '<li>30-day hassle-free return policy</li>' +
          '<li>Items must be in original packaging, unused condition</li>' +
          '<li>Free return shipping on defective items</li>' +
          '<li>Refund processed within 5-7 business days</li>' +
          '</ul>' +
          '</div>' +
          '<div class="stehlen-tabs__panel" data-panel="warranty">' +
          '<h3>Manufacturer Warranty</h3>' +
          '<p>All products sold by Stehlen Auto come with a manufacturer warranty. This warranty covers defects in materials and workmanship under normal use and service conditions.</p>' +
          '<ul>' +
          '<li>Coverage varies by product - see product description for details</li>' +
          '<li>Warranty does not cover damage from improper installation</li>' +
          '<li>Contact our support team for warranty claims</li>' +
          '</ul>' +
          '<p style="margin-top:16px;"><strong>Need help?</strong> Call us at (909) 895-4112 or email support.</p>' +
          '</div>' +
          '</div>';

        var parentSection = productSection.closest('.shopify-section');
        if (parentSection) {
          parentSection.insertAdjacentHTML('afterend', '<div class="shopify-section">' + tabsHtml + '</div>');
        }

        // Tab click handler
        document.querySelectorAll('.stehlen-tabs__btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            document.querySelectorAll('.stehlen-tabs__btn').forEach(function(b) { b.classList.remove('stehlen-tabs__btn--active'); });
            document.querySelectorAll('.stehlen-tabs__panel').forEach(function(p) { p.classList.remove('stehlen-tabs__panel--active'); });
            btn.classList.add('stehlen-tabs__btn--active');
            var panel = document.querySelector('[data-panel="' + btn.getAttribute('data-tab') + '"]');
            if (panel) panel.classList.add('stehlen-tabs__panel--active');
          });
        });
      }
    }
  });
</script>

<!-- Product tags data for fitment check -->
<script id="stehlen-product-tags-data" type="application/json">{{ product.tags | json }}</script>
<!-- Product description for tabs -->
<script id="stehlen-product-desc-data" type="application/json">{{ product.description | json }}</script>
{% endif %}
