{% comment %}
  My Garage — Save multiple vehicles and switch between them
  Stored in localStorage as JSON array
{% endcomment %}

<div id="stehlen-garage-trigger" title="My Garage" style="display:none;">
  <button id="garage-btn" aria-label="My Garage">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
    <span id="garage-count" style="display:none;">0</span>
  </button>
</div>

<!-- Garage Drawer -->
<div id="stehlen-garage-drawer" class="garage-drawer" aria-hidden="true">
  <div class="garage-drawer__backdrop"></div>
  <div class="garage-drawer__panel">
    <div class="garage-drawer__header">
      <h3>My Garage</h3>
      <button class="garage-drawer__close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <div class="garage-drawer__body">
      <div id="garage-vehicles"></div>
      <button id="garage-add-btn" class="garage-drawer__add">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Add a Vehicle
      </button>
    </div>
    <div id="garage-add-form" class="garage-drawer__form" style="display:none;">
      <h4>Add Vehicle</h4>
      <select id="garage-year"><option value="">Year</option></select>
      <select id="garage-make" disabled><option value="">Make</option></select>
      <select id="garage-model" disabled><option value="">Model</option></select>
      <div class="garage-drawer__form-actions">
        <button id="garage-save-btn" class="garage-drawer__save" disabled>Save Vehicle</button>
        <button id="garage-cancel-btn" class="garage-drawer__cancel">Cancel</button>
      </div>
    </div>
  </div>
</div>

<style>
  #stehlen-garage-trigger {
    position: relative;
  }
  #garage-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    padding: 4px;
    position: relative;
  }
  #garage-count {
    position: absolute;
    top: -4px;
    right: -6px;
    background: #FFB74F;
    color: #1A1A1A;
    font-size: 0.625rem;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body--family, sans-serif);
  }

  .garage-drawer { position: fixed; inset: 0; z-index: 9999; pointer-events: none; }
  .garage-drawer[aria-hidden="false"] { pointer-events: all; }
  .garage-drawer__backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .garage-drawer[aria-hidden="false"] .garage-drawer__backdrop { opacity: 1; }
  .garage-drawer__panel {
    position: absolute; right: 0; top: 0; bottom: 0;
    width: 360px; max-width: 90vw;
    background: #fff;
    box-shadow: -4px 0 20px rgba(0,0,0,0.1);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .garage-drawer[aria-hidden="false"] .garage-drawer__panel { transform: translateX(0); }
  .garage-drawer__header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px;
    border-bottom: 1px solid #e0e0e0;
  }
  .garage-drawer__header h3 {
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #1A1A1A;
    margin: 0;
  }
  .garage-drawer__close {
    background: none; border: none; cursor: pointer; color: #666; padding: 4px;
  }
  .garage-drawer__body { flex: 1; overflow-y: auto; padding: 20px; }

  .garage-vehicle {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px; margin-bottom: 8px;
    border: 1px solid #e0e0e0; border-radius: 4px;
    transition: border-color 0.2s;
  }
  .garage-vehicle--active { border-color: #1A3F22; background: #f0f7f1; }
  .garage-vehicle__info {
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.875rem; color: #1A1A1A;
  }
  .garage-vehicle__info strong {
    display: block; font-weight: 600;
  }
  .garage-vehicle__actions { display: flex; gap: 8px; }
  .garage-vehicle__select {
    background: #1A3F22; color: #fff;
    border: none; border-radius: 4px;
    padding: 6px 12px; font-size: 0.75rem;
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-weight: 600; text-transform: uppercase;
    cursor: pointer;
  }
  .garage-vehicle--active .garage-vehicle__select { background: #ccc; color: #666; }
  .garage-vehicle__remove {
    background: none; border: none; cursor: pointer; color: #999; padding: 4px;
    font-size: 0.75rem;
  }
  .garage-vehicle__remove:hover { color: #FF4E4E; }

  .garage-drawer__add {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 12px;
    background: #f5f5f5; border: 1px dashed #ccc; border-radius: 4px;
    cursor: pointer; color: #1A3F22;
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-weight: 600; font-size: 0.875rem;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .garage-drawer__add:hover { background: #ebebeb; }

  .garage-drawer__form {
    padding: 20px; border-top: 1px solid #e0e0e0;
  }
  .garage-drawer__form h4 {
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-size: 1rem; font-weight: 600; text-transform: uppercase;
    margin: 0 0 12px; color: #1A1A1A;
  }
  .garage-drawer__form select {
    width: 100%; padding: 10px; margin-bottom: 8px;
    border: 1px solid #ccc; border-radius: 4px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.875rem;
  }
  .garage-drawer__form-actions { display: flex; gap: 8px; margin-top: 12px; }
  .garage-drawer__save {
    flex: 1; padding: 10px; background: #1A3F22; color: #fff;
    border: none; border-radius: 4px; cursor: pointer;
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-weight: 600; text-transform: uppercase;
  }
  .garage-drawer__save:disabled { background: #ccc; cursor: not-allowed; }
  .garage-drawer__cancel {
    flex: 1; padding: 10px; background: #f5f5f5; color: #333;
    border: 1px solid #ccc; border-radius: 4px; cursor: pointer;
    font-family: var(--font-heading--family, Oswald, sans-serif);
    font-weight: 600; text-transform: uppercase;
  }

  .garage-empty {
    text-align: center; padding: 24px;
    font-family: var(--font-body--family, sans-serif);
    color: #666; font-size: 0.875rem;
  }
</style>

<script>
(function() {
  // YMM data (simplified — using major truck makes/models)
  var YMM = {
    years: Array.from({length: 30}, function(_, i) { return String(2025 - i); }),
    makes: ['Chevrolet', 'Dodge', 'Ford', 'GMC', 'Honda', 'Jeep', 'Nissan', 'Ram', 'Toyota'],
    models: {
      'Chevrolet': ['Colorado', 'Silverado 1500', 'Silverado 2500HD', 'Silverado 3500HD'],
      'Dodge': ['Dakota', 'Durango', 'Ram 1500', 'Ram 2500', 'Ram 3500'],
      'Ford': ['Bronco', 'F-150', 'F-250', 'F-350', 'Maverick', 'Ranger'],
      'GMC': ['Canyon', 'Sierra 1500', 'Sierra 2500HD', 'Sierra 3500HD'],
      'Honda': ['Ridgeline'],
      'Jeep': ['Gladiator', 'Wrangler'],
      'Nissan': ['Frontier', 'Titan', 'Titan XD'],
      'Ram': ['1500', '2500', '3500'],
      'Toyota': ['Tacoma', 'Tundra']
    }
  };

  function getGarage() {
    try { return JSON.parse(localStorage.getItem('stehlen_garage') || '[]'); }
    catch(e) { return []; }
  }
  function saveGarage(arr) { localStorage.setItem('stehlen_garage', JSON.stringify(arr)); }
  function getActive() {
    try { return JSON.parse(localStorage.getItem('stehlen_vehicle')); }
    catch(e) { return null; }
  }
  function setActive(v) { localStorage.setItem('stehlen_vehicle', JSON.stringify(v)); }

  var drawer = document.getElementById('stehlen-garage-drawer');
  var vehicleList = document.getElementById('garage-vehicles');
  var addBtn = document.getElementById('garage-add-btn');
  var addForm = document.getElementById('garage-add-form');
  var trigger = document.getElementById('stehlen-garage-trigger');
  var garageBtn = document.getElementById('garage-btn');
  var countEl = document.getElementById('garage-count');

  // Populate Year dropdown
  var yearSel = document.getElementById('garage-year');
  var makeSel = document.getElementById('garage-make');
  var modelSel = document.getElementById('garage-model');
  var saveBtn = document.getElementById('garage-save-btn');

  YMM.years.forEach(function(y) {
    var opt = document.createElement('option');
    opt.value = y; opt.textContent = y;
    yearSel.appendChild(opt);
  });

  yearSel.addEventListener('change', function() {
    makeSel.innerHTML = '<option value="">Make</option>';
    modelSel.innerHTML = '<option value="">Model</option>';
    modelSel.disabled = true;
    saveBtn.disabled = true;
    if (this.value) {
      makeSel.disabled = false;
      YMM.makes.forEach(function(m) {
        var opt = document.createElement('option');
        opt.value = m; opt.textContent = m;
        makeSel.appendChild(opt);
      });
    } else {
      makeSel.disabled = true;
    }
  });

  makeSel.addEventListener('change', function() {
    modelSel.innerHTML = '<option value="">Model</option>';
    saveBtn.disabled = true;
    if (this.value && YMM.models[this.value]) {
      modelSel.disabled = false;
      YMM.models[this.value].forEach(function(m) {
        var opt = document.createElement('option');
        opt.value = m; opt.textContent = m;
        modelSel.appendChild(opt);
      });
    } else {
      modelSel.disabled = true;
    }
  });

  modelSel.addEventListener('change', function() {
    saveBtn.disabled = !this.value;
  });

  function renderGarage() {
    var garage = getGarage();
    var active = getActive();
    countEl.textContent = garage.length;
    countEl.style.display = garage.length > 0 ? 'flex' : 'none';

    if (garage.length === 0) {
      vehicleList.innerHTML = '<div class="garage-empty">No vehicles saved yet. Add your vehicle to check fitment across the store.</div>';
      return;
    }
    var html = '';
    garage.forEach(function(v, i) {
      var isActive = active && active.year === v.year && active.make === v.make && active.model === v.model;
      html += '<div class="garage-vehicle' + (isActive ? ' garage-vehicle--active' : '') + '">' +
        '<div class="garage-vehicle__info"><strong>' + v.year + ' ' + v.make + ' ' + v.model + '</strong>' +
        (isActive ? '<span style="color:#1A3F22;font-size:.75rem;">Currently active</span>' : '') +
        '</div><div class="garage-vehicle__actions">' +
        '<button class="garage-vehicle__select" data-idx="' + i + '">' + (isActive ? 'Active' : 'Select') + '</button>' +
        '<button class="garage-vehicle__remove" data-idx="' + i + '">Remove</button>' +
        '</div></div>';
    });
    vehicleList.innerHTML = html;

    // Bind events
    vehicleList.querySelectorAll('.garage-vehicle__select').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(this.getAttribute('data-idx'));
        var v = getGarage()[idx];
        setActive(v);
        renderGarage();
        // Reload page to update fitment indicators
        window.location.reload();
      });
    });
    vehicleList.querySelectorAll('.garage-vehicle__remove').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(this.getAttribute('data-idx'));
        var garage = getGarage();
        var removed = garage.splice(idx, 1)[0];
        saveGarage(garage);
        // If removed vehicle was active, clear active
        var active = getActive();
        if (active && active.year === removed.year && active.make === removed.make && active.model === removed.model) {
          if (garage.length > 0) setActive(garage[0]);
          else localStorage.removeItem('stehlen_vehicle');
        }
        renderGarage();
      });
    });
  }

  // Toggle drawer
  function openDrawer() {
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    renderGarage();
  }
  function closeDrawer() {
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    addForm.style.display = 'none';
  }

  garageBtn.addEventListener('click', openDrawer);
  drawer.querySelector('.garage-drawer__backdrop').addEventListener('click', closeDrawer);
  drawer.querySelector('.garage-drawer__close').addEventListener('click', closeDrawer);

  addBtn.addEventListener('click', function() { addForm.style.display = 'block'; });
  document.getElementById('garage-cancel-btn').addEventListener('click', function() {
    addForm.style.display = 'none';
  });

  saveBtn.addEventListener('click', function() {
    var v = { year: yearSel.value, make: makeSel.value, model: modelSel.value };
    var garage = getGarage();
    // Check for duplicates
    var exists = garage.some(function(g) { return g.year === v.year && g.make === v.make && g.model === v.model; });
    if (!exists) {
      garage.push(v);
      saveGarage(garage);
      setActive(v);
    }
    addForm.style.display = 'none';
    yearSel.value = ''; makeSel.innerHTML = '<option value="">Make</option>'; modelSel.innerHTML = '<option value="">Model</option>';
    makeSel.disabled = true; modelSel.disabled = true; saveBtn.disabled = true;
    renderGarage();
  });

  // Insert garage trigger into header actions
  trigger.style.display = 'block';
  var headerActions = document.querySelector('header-actions, .header-actions');
  if (headerActions) {
    headerActions.parentNode.insertBefore(trigger, headerActions);
  } else {
    // Fallback: insert before cart
    var cart = document.querySelector('.cart-icon-component, [href*="/cart"]');
    if (cart && cart.parentNode) {
      cart.parentNode.insertBefore(trigger, cart);
    }
  }

  renderGarage();
})();
</script>
