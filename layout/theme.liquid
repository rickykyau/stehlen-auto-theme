<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% render 'card-enhancements' %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    {% render 'rotating-announcements' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <!-- Value Props Bar -->
    <div id="stehlen-value-props" style="background:#fff;border-bottom:1px solid #e0e0e0;">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);max-width:1200px;margin:0 auto;padding:0 20px;">
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;padding:18px 12px;border-right:1px solid #e0e0e0;">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <div style="display:flex;flex-direction:column;gap:2px;">
            <span style="font-family:var(--font-heading--family,Oswald,sans-serif);font-weight:600;font-size:.8125rem;letter-spacing:.03em;text-transform:uppercase;color:#1A1A1A;">Free Shipping</span>
            <span style="font-family:var(--font-body--family,sans-serif);font-size:.75rem;color:#666;">On all orders</span>
          </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;padding:18px 12px;border-right:1px solid #e0e0e0;">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
          <div style="display:flex;flex-direction:column;gap:2px;">
            <span style="font-family:var(--font-heading--family,Oswald,sans-serif);font-weight:600;font-size:.8125rem;letter-spacing:.03em;text-transform:uppercase;color:#1A1A1A;">Guaranteed Fitment</span>
            <span style="font-family:var(--font-body--family,sans-serif);font-size:.75rem;color:#666;">Fits your vehicle or money back</span>
          </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;padding:18px 12px;border-right:1px solid #e0e0e0;">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4l2 2"></path></svg>
          <div style="display:flex;flex-direction:column;gap:2px;">
            <span style="font-family:var(--font-heading--family,Oswald,sans-serif);font-weight:600;font-size:.8125rem;letter-spacing:.03em;text-transform:uppercase;color:#1A1A1A;">Manufacturer Warranty</span>
            <span style="font-family:var(--font-body--family,sans-serif);font-size:.75rem;color:#666;">On every product</span>
          </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;padding:18px 12px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FFB74F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
          <div style="display:flex;flex-direction:column;gap:2px;">
            <span style="font-family:var(--font-heading--family,Oswald,sans-serif);font-weight:600;font-size:.8125rem;letter-spacing:.03em;text-transform:uppercase;color:#1A1A1A;">Easy Returns</span>
            <span style="font-family:var(--font-body--family,sans-serif);font-size:.75rem;color:#666;">30-day hassle-free returns</span>
          </div>
        </div>
      </div>
    </div>
    <style>
      @media screen and (max-width:989px){
        #stehlen-value-props > div { grid-template-columns: repeat(2,1fr) !important; }
        #stehlen-value-props > div > div:nth-child(2) { border-right: none !important; }
        #stehlen-value-props > div > div:nth-child(1),
        #stehlen-value-props > div > div:nth-child(2) { border-bottom: 1px solid #e0e0e0; }
      }
      @media screen and (max-width:749px){
        #stehlen-value-props > div > div { padding: 12px 8px !important; gap: 8px !important; }
        #stehlen-value-props svg { width: 22px !important; height: 22px !important; }
        #stehlen-value-props span:last-child { display: none !important; }
      }
    </style>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% render 'footer-trust' %}
    {% sections 'footer-group' %}

    {% render 'search-modal' %}
    {% render 'pdp-enhancements' %}
    {% render 'my-garage' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
